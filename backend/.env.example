# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/eco-lender?retryWrites=true&w=majority
MONGODB_LOCAL=mongodb://localhost:27017/eco-lender

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=7d

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI & ML Services
OPENAI_API_KEY=your_openai_api_key

# Admin Configuration
ADMIN_EMAIL=admin@ecolender.com
ADMIN_PASSWORD=change_this_default_password

# Application Settings
APP_NAME=Eco-Lender
APP_VERSION=1.0.0
